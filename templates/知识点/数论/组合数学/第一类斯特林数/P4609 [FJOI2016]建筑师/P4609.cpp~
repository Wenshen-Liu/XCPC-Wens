#include<bits/stdc++.h>
using namespace std;
int t;
int n,A,B;
const long long mod=1e9+7;
long long s[50001][205],c[201][205];
int main(){
	cin>>t;
    s[0][0]=1;
    for(int i=1;i<=50000;++i){
        for(int j=1;j<=200;++j){
            s[i][j]=((s[i-1][j-1]%mod+s[i-1][j]%mod*(i-1)%mod)%mod)%mod;
        }
    }
    c[0][0]=1;
    
    for(int i=1;i<=200;++i){
        c[i][0]=1;
        for(int j=1;j<=i;++j)
        c[i][j]=(c[i-1][j]%mod+c[i-1][j-1]%mod)%mod;
    }
    while(t--){
    	cin>>n>>A>>B;
        cout<<(s[n-1][A+B-2]%mod*c[A+B-2][A-1]%mod)%mod<<endl;
    }
    return 0;
}
