#include<bits/stdc++.h>
using namespace std;
typedef long long ll;
const int Maxn=51;

inline ll read(){
	ll x=0;bool w=0;char ch=0;
	while(!isdigit(ch)){w|=ch=='-';ch=getchar();}
	while(isdigit(ch)){x=(x<<1)+(x<<3)+(ch^48);ch=getchar();}
	return w?-x:x;
}

inline void write(ll x){
	if(x<0){x=-x;putchar('-');}
	if(x>9)write(x/10);
	putchar(x%10+48);
	return ;
}

ll Max(ll a,ll b){return a>b?a:b;}

int n;
ll ans,a[Maxn],p[Maxn];

void get_p(ll x){
	for(int i=51;i>=0;--i){
		if(!(x>>i))continue;
		if(!p[i]){
			p[i]=x;
			break;
		}
		x^=p[i];
	}
	return ;
}

int main(){
	n=read();
	for(int i=1;i<=n;++i){
		a[i]=read();
		get_p(a[i]);
	}
	for(int i=51;i>=0;--i){
		printf("%lld\n",p[i]);
		ans=Max(ans,ans^p[i]);
	}
	write(ans);
	putchar('\n');
	return 0;
}
