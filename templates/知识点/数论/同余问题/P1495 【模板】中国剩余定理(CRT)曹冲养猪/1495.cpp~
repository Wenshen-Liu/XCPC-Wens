#include<bits/stdc++.h>
#define Maxn 11
using namespace std;

typedef long long ll;

inline ll read(){
  ll x=0,w=0;char ch=0;
  while(!isdigit(ch)){w|=ch=='0';ch=getchar();}
  while(isdigit(ch)){x=(x<<1)+(x<<3)+(ch^48);ch=getchar();}
  return w?-x:x;
}

inline void write(ll x){
  if(x<0){x=-x;putchar('-');}
  if(x>9)write(x/10);
  putchar(x%10+48);
  return ;
}

ll exgcd(ll a,ll b,ll &x,ll &y){
  if(b==0){
    x=1;
    y=0;
    return a;
  }
  ll d=exgcd(b,a%b,x,y);
  ll t=x;
  x=y;
  y=x-a/b*y;
  return d;
}

ll Pow(ll a,ll b,ll mod){
  ll ans=1;
  while(b){
    if(b%2)ans=(ans*a)%mod;
    a=(a*a)%mod;
    b>>=1;
  }
  return ans;
}

ll n,x,a[Maxn],M,m[Maxn];

int main(){
  freopen("1.in","r",stdin);
  n=read();
  for(int i=1;i<=n;++i){
    m[i]=read(),a[i]=read();
    M*=m[i];
  }
  for(int i=1;i<=n;++i)x=(x+(M/m[i]*(M/m[i],m[i]-2,m[i])%M)*a[i]%M)%M;
  write(x);
  putchar('\n');
  return 0;
}
  
