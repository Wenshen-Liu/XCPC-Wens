#include<bits/stdc++.h>
#define N 50010
using namespace std;
typedef long long ll;

inline ll read(){
    ll X=0,w=0; char ch=0;
    while(!isdigit(ch)) {w|=ch=='-';ch=getchar();}
    while(isdigit(ch)) X=(X<<3)+(X<<1)+(ch^48),ch=getchar();
    return w?-X:X;
}

int n,block;
int a[N],blo[N];

int Min(int a,int b){return a<b?a:b;}
int Max(int a,int b){return a>b?a:b;}
struct kuai{
  ll head,tail,lazy;
}b[25000];
int main(){
  n=read();
  block=sqrt(n);
  for(int i=1;i<=n;++i){
    a[i]=read();
    blo[i]=i/block;
  }
  for(int i=n+1;i<=block+n;++i){
    blo[i]=i/block;
  }
  for(int i=0;i<=block+1;++i){
    b[i].head=i*block;
    b[i].tail=(i+1)*block-1;
  }
  for(int i=1;i<=n;++i){
    int opt=read(),l=read(),r=read(),c=read();
    if(opt==0){
      for(int j=l;b[blo[l]].tail<r&&j<=b[blo[l]].tail;++j){
	a[j]+=c;
      }
      for(int j=blo[l]+1;b[j].tail<r;++j){
	b[j].lazy+=c;
      }
      for(int j=b[blo[r]].head;j<=r;++j){
	a[j]+=c;
      }
    }
    if(opt==1){
      for(int j=Max(1,b[blo[r]].head);j<=Min(b[blo[r]].tail,r);++j){
	a[j]+=b[blo[r]].lazy;
      }
      b[blo[r]].lazy=0;
      cout<<a[r]<<endl;
    }
  }
  return 0;
}
