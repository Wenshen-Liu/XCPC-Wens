{
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "macFrameworkPath": [
                "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/System/Library/Frameworks"
            ],
            // 关键：指定真正的 GCC 路径
            "compilerPath": "/opt/homebrew/bin/g++-15",
            // 关键：设置为 gcc 模式，否则它会按 clang 的逻辑去找头文件
            "intelliSenseMode": "macos-gcc-arm64",
            "cppStandard": "c++20"
        }
    ],
    "version": 4
}