{
    "C_Cpp.default.compilerPath": "/opt/homebrew/bin/g++-15",

    "c-cpp-compile-run.c-compiler": "/opt/homebrew/bin/g++-15",
    "c-cpp-compile-run.cpp-compiler": "/opt/homebrew/bin/g++-15",
    "c-cpp-compile-run.cpp-flags": "-Wall -Wextra -g3 -std=c++20",
    "c-cpp-compile-run.save-before-compile": true,
    "c-cpp-compile-run.output-location": "/Users/wens/Work/XCPC/output",

    "code-runner.executorMap": {
        "cpp": "cd $dir && g++-15 -std=c++20 $fileName -o output/$fileNameWithoutExt && ./output/$fileNameWithoutExt"
    },
    "code-runner.runInTerminal": true,
    "code-runner.saveFileBeforeRun": true
}